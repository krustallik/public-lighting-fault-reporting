# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=lighting_faults
DB_USER=postgres
DB_PASSWORD=postgres

# Backend
NODE_ENV=development
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production-use-long-random-string
# Set on first run to replace PLACEHOLDER_HASH in seed (username: admin)
ADMIN_INITIAL_PASSWORD=admin123

# Frontend (used by Vite — must be reachable from the browser)
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:5000/api
# Non-default admin UI path (security through obscurity; login still required)
VITE_ADMIN_BASE_PATH=/panel-svietidla

# AUSEMIO / DPMK integration
AUSEMIO_BASE_URL=https://kosice.ausemio.io/public_issues
AUSEMIO_API_KEY=
AUSEMIO_TEST_MODE=true
AUSEMIO_LOCALE=sk

# Reverse geocoding (OpenStreetMap Nominatim)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="PublicLightingFaultReporting/1.0 (thesis; contact: admin@example.com)"
NOMINATIM_ACCEPT_LANGUAGE=sk
NOMINATIM_MIN_INTERVAL_MS=1100
